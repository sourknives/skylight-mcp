# Skylight MCP Server Configuration
# Copy this file to .env and fill in your values, OR set these as env vars
# directly in your MCP host's settings (e.g. Claude Desktop settings.json).

# ============================================
# AUTHENTICATION (OAuth refresh-token flow)
# ============================================
# As of early 2026, Skylight's legacy /api/sessions email/password login
# is deprecated. We now use the OAuth refresh-token flow used by the
# official web app at https://app.ourskylight.com.
#
# Skylight's Doorkeeper rotates the refresh_token on every /oauth/token
# call. This server transparently persists the rotated token to a cache
# file on disk; you only need to bootstrap the seed token here. If the
# seed becomes invalid (e.g. revoked server-side, or the cache is lost
# and the seed has already been spent elsewhere), re-capture it.
#
# To bootstrap:
#   1. Log in at https://app.ourskylight.com in your browser.
#   2. Open DevTools > Console and run:
#        (async () => {
#          const s = JSON.parse(localStorage['mmkv.default\\auth-storage']).state;
#          const js = [...document.scripts].map(x=>x.src).find(x=>x.includes('_expo') && x.includes('index-'));
#          const txt = await fetch(js).then(r=>r.text());
#          const m = txt.match(/client_id[:=]\s*['"]([A-Za-z0-9_-]{8,})['"]/);
#          console.log({
#            SKYLIGHT_CLIENT_ID: m && m[1],
#            SKYLIGHT_REFRESH_TOKEN: s.refreshToken,
#            SKYLIGHT_FINGERPRINT: s.uniqueId,
#          });
#        })();
#   3. Frame ID is in the URL after you click your calendar:
#      https://ourskylight.com/calendar/{SKYLIGHT_FRAME_ID}

SKYLIGHT_CLIENT_ID=your_oauth_client_id
SKYLIGHT_REFRESH_TOKEN=your_refresh_token
SKYLIGHT_FINGERPRINT=your_device_uuid
SKYLIGHT_FRAME_ID=your_frame_id

# ============================================
# OPTIONAL
# ============================================

# Directory where the persisted OAuth token cache is written. If unset,
# defaults to a platform-specific user config directory:
#   Windows: %APPDATA%\skylight-mcp\
#   macOS:   ~/Library/Application Support/skylight-mcp/
#   Linux:   ${XDG_CONFIG_HOME:-~/.config}/skylight-mcp/
# SKYLIGHT_CACHE_DIR=/custom/path

# Default timezone for date operations (default: America/New_York)
# SKYLIGHT_TIMEZONE=America/New_York
